# V.A.U.L.T environment — copy to .env and fill in values

# LLM provider (Instructor supports 15+ providers)
VAULT_LLM_PROVIDER=openai/gpt-4o-mini
OPENAI_API_KEY=

# Neo4j
VAULT_NEO4J_URI=bolt://localhost:7687
VAULT_NEO4J_USER=neo4j
VAULT_NEO4J_PASSWORD=vault-dev-password

# Temporal
VAULT_TEMPORAL_HOST=localhost:7233
VAULT_TEMPORAL_NAMESPACE=default
VAULT_TEMPORAL_TASK_QUEUE=vault-pipeline

# Embeddings (local, no API key needed)
VAULT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Validation thresholds
VAULT_GROUNDING_MIN_SCORE=0.75
VAULT_COMPREHENSION_MIN_SCORE=0.70

# Optional: Instagram cookie auth
# VAULT_INSTAGRAM_COOKIES_FROM_BROWSER=chrome
